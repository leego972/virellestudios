# ============================================================
# VIRELLE STUDIOS — Environment Variables
# ============================================================
# Copy to .env for local development. Store production values in Render.
# Never commit real passwords, tokens, API keys or connection strings.
# See DEPLOYMENT.md for current production setup.
# ============================================================

# Core runtime
NODE_ENV=development
PORT=3000
PUBLIC_APP_URL=http://localhost:3000
VITE_APP_ID=virelle-local
VITE_APP_TITLE=Virelle Studios
VITE_APP_LOGO=/virelle-logo-square.png

# MySQL 8-compatible database
DATABASE_URL=mysql://user:password@localhost:3306/virelle

# Redis
REDIS_URL=redis://localhost:6379

# Authentication and sessions
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
SESSION_SECRET=replace-with-a-separate-random-secret-of-at-least-32-characters
OAUTH_SERVER_URL=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Current self-serve membership price IDs
STRIPE_INDIE_MONTHLY_PRICE_ID=price_...
STRIPE_INDIE_ANNUAL_PRICE_ID=price_...
STRIPE_CREATOR_MONTHLY_PRICE_ID=price_...
STRIPE_CREATOR_ANNUAL_PRICE_ID=price_...
STRIPE_STUDIO_MONTHLY_PRICE_ID=price_...
STRIPE_STUDIO_ANNUAL_PRICE_ID=price_...

# Credit top-up price IDs
STRIPE_TOPUP_10_PRICE_ID=price_...
STRIPE_TOPUP_30_PRICE_ID=price_...
STRIPE_TOPUP_100_PRICE_ID=price_...
STRIPE_TOPUP_200_PRICE_ID=price_...
STRIPE_TOPUP_500_PRICE_ID=price_...
STRIPE_TOPUP_1000_PRICE_ID=price_...

# Designer marketplace and Stripe Connect
STRIPE_DESIGNER_YEARLY_PRICE_ID=price_...
STRIPE_CONNECT_RETURN_URL=http://localhost:3000/settings?tab=billing
STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/settings?tab=billing

# Adult Studio verification
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=VA...

# AI provider integrations
# Users may supply their own BYOK keys. Platform keys are optional unless a
# particular managed integration is intentionally enabled.
OPENAI_API_KEY=
RUNWAY_API_KEY=
FAL_KEY=
GOOGLE_API_KEY=
HUGGING_FACE_API_KEY=
GROQ_API_KEY=
POLLINATIONS_API_KEY=
VENICE_API_KEY=
TITAN_API_URL=
TITAN_API_KEY=

# Transactional email
GMAIL_USER=
GMAIL_APP_PASSWORD=
RESEND_API_KEY=
EMAIL_FROM=Virelle Studios <no-reply@example.com>

# Administration
ADMIN_EMAIL=admin@example.com

# S3-compatible application storage
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=virelle-uploads
AWS_S3_ENDPOINT=
AWS_S3_PUBLIC_URL=

# Private compliance archive
COMPLIANCE_ARCHIVE_BUCKET=virelle-compliance-private
COMPLIANCE_RETENTION_DAYS=90
COMPLIANCE_ARCHIVE_ENABLED=true
COMPLIANCE_ARCHIVE_SCAN_INTERVAL_MS=300000
COMPLIANCE_ARCHIVE_BATCH_SIZE=3
COMPLIANCE_ARCHIVE_MAX_BYTES=2147483648
COMPLIANCE_SIGNED_URL_SECONDS=300

# Managed broadcast bridge
BROADCAST_BRIDGE_URL=https://broadcast-bridge.example.com/sessions
BROADCAST_BRIDGE_TOKEN=replace-with-a-long-random-secret

# Error tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
VITE_SENTRY_DSN=

# Verified downloadable releases
IOS_DOWNLOAD_URL=
ANDROID_DOWNLOAD_URL=
DESKTOP_RELEASES_REPO=leego972/virellestudios
DESKTOP_MAC_URL=
DESKTOP_WIN_URL=
DESKTOP_LINUX_URL=
DESKTOP_VERSION=
GITHUB_TOKEN=

# Optional social and distribution channels
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_CHANNEL_ID=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
META_ACCESS_TOKEN=
X_API_KEY=
X_API_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
LINKEDIN_ACCESS_TOKEN=
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

# Optional SEO integration
GOOGLE_INDEXING_SA_KEY=
