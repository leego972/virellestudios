# ============================================================
  # VIRELLE STUDIOS — Environment Variables
  # ============================================================
  # Copy this file to .env and fill in your values.
  # NEVER commit .env to version control.
  # See DEPLOYMENT.md for setup instructions.
  # ============================================================

  # ── Core ─────────────────────────────────────────────────────
  NODE_ENV=development
  PORT=3000

  # ── Database (PostgreSQL) ────────────────────────────────────
  # Required. Get from Railway PostgreSQL plugin or any Postgres host.
  DATABASE_URL=postgresql://user:password@host:5432/virelle

  # ── Redis (rate limiting + job queues) ───────────────────────
  # Required for production. Get from Railway Redis plugin or Upstash.
  REDIS_URL=redis://localhost:6379

  # ── Auth ─────────────────────────────────────────────────────
  # Required. Use a long random secret (min 32 chars).
  JWT_SECRET=your-jwt-secret-minimum-32-characters-long

  # ── Stripe (payments) ────────────────────────────────────────
  # Required for subscriptions and top-ups.
  STRIPE_SECRET_KEY=sk_test_...
  STRIPE_PUBLISHABLE_KEY=pk_test_...
  STRIPE_WEBHOOK_SECRET=whsec_...

  # Subscription price IDs — create these in Stripe Dashboard
  STRIPE_INDIE_MONTHLY_PRICE_ID=price_...
  STRIPE_INDIE_ANNUAL_PRICE_ID=price_...
  STRIPE_CREATOR_MONTHLY_PRICE_ID=price_...
  STRIPE_CREATOR_ANNUAL_PRICE_ID=price_...
  STRIPE_STUDIO_MONTHLY_PRICE_ID=price_...
  STRIPE_STUDIO_ANNUAL_PRICE_ID=price_...

  # Credit top-up pack price IDs
  STRIPE_TOPUP_10_PRICE_ID=price_...
  STRIPE_TOPUP_30_PRICE_ID=price_...
  STRIPE_TOPUP_100_PRICE_ID=price_...

  # Stripe Connect (designer marketplace payouts)
  STRIPE_CONNECT_RETURN_URL=https://virelle.life/settings?tab=billing
  STRIPE_CONNECT_REFRESH_URL=https://virelle.life/settings?tab=billing

  # ── AI Generation Providers ───────────────────────────────────
  # Platform-level keys used as fallback for admin/testing.
  # Users supply their own BYOK keys via Settings.
  OPENAI_API_KEY=sk-...
  RUNWAY_API_KEY=...
  FAL_KEY=...
  GOOGLE_API_KEY=...
  HUGGING_FACE_API_KEY=...
  GROQ_API_KEY=gsk_...

  # ── Email (Gmail app password) ────────────────────────────────
  # Required for transactional email (signup, password reset).
  GMAIL_USER=studiosvirelle@gmail.com
  GMAIL_APP_PASSWORD=your-gmail-app-password
  EMAIL_FROM=Virelle Studios <studiosvirelle@gmail.com>

  # ── Admin ─────────────────────────────────────────────────────
  ADMIN_EMAIL=your-admin-email@example.com

  # ── App Storage (S3-compatible) ───────────────────────────────
  # Optional. Required for user media uploads.
  AWS_REGION=ap-southeast-2
  AWS_ACCESS_KEY_ID=...
  AWS_SECRET_ACCESS_KEY=...
  AWS_S3_BUCKET=virelle-uploads

  # ── Social Media Channels (optional) ─────────────────────────
  # Only required if using autonomous social publishing features.
  YOUTUBE_API_KEY=
  YOUTUBE_CLIENT_ID=
  YOUTUBE_CLIENT_SECRET=
  YOUTUBE_CHANNEL_ID=
  TIKTOK_CLIENT_KEY=
  TIKTOK_CLIENT_SECRET=
  META_ACCESS_TOKEN=
  X_API_KEY=
  X_API_SECRET=
  INSTAGRAM_CLIENT_ID=
  INSTAGRAM_CLIENT_SECRET=
  DISCORD_BOT_TOKEN=
  DISCORD_CHANNEL_ID=
  TELEGRAM_BOT_TOKEN=
  TELEGRAM_CHANNEL_ID=
  LINKEDIN_ACCESS_TOKEN=
  SNAPCHAT_CLIENT_ID=
  SNAPCHAT_CLIENT_SECRET=

  # ── Google Indexing (optional SEO) ────────────────────────────
  # Base64-encoded service account JSON for Google Search Console
  GOOGLE_INDEXING_SA_KEY=
  