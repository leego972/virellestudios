# ============================================================
# VIRELLE STUDIOS — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# See DEPLOYMENT.md for setup instructions.
# ============================================================

# ── Core ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@host:3306/virelle

# ── Redis (rate limiting + job queues) ───────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# ── Stripe (payments + mature identity/card verification) ────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_INDIE_MONTHLY_PRICE_ID=price_...
STRIPE_INDIE_ANNUAL_PRICE_ID=price_...
STRIPE_CREATOR_MONTHLY_PRICE_ID=price_...
STRIPE_CREATOR_ANNUAL_PRICE_ID=price_...
STRIPE_STUDIO_MONTHLY_PRICE_ID=price_...
STRIPE_STUDIO_ANNUAL_PRICE_ID=price_...
STRIPE_TOPUP_10_PRICE_ID=price_...
STRIPE_TOPUP_30_PRICE_ID=price_...
STRIPE_TOPUP_100_PRICE_ID=price_...
STRIPE_CONNECT_RETURN_URL=https://virelle.life/settings?tab=billing
STRIPE_CONNECT_REFRESH_URL=https://virelle.life/settings?tab=billing

# ── Mature access phone 2FA (Twilio Verify) ──────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_VERIFY_SERVICE_SID=VA...

# ── AI Generation Providers ───────────────────────────────────
OPENAI_API_KEY=sk-...
RUNWAY_API_KEY=...
FAL_KEY=...
GOOGLE_API_KEY=...
HUGGING_FACE_API_KEY=...
GROQ_API_KEY=gsk_...

# ── Email ─────────────────────────────────────────────────────
GMAIL_USER=studiosvirelle@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
EMAIL_FROM=Virelle Studios <studiosvirelle@gmail.com>

# ── Admin ─────────────────────────────────────────────────────
ADMIN_EMAIL=your-admin-email@example.com

# ── App Storage (S3 / Cloudflare R2 compatible) ───────────────
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=virelle-uploads
AWS_S3_ENDPOINT=
AWS_S3_PUBLIC_URL=

# ── Private Compliance Archive ────────────────────────────────
# Production requires a separate private bucket. Objects are never exposed
# through public URLs; authorised admin downloads use short-lived signed URLs.
COMPLIANCE_ARCHIVE_ENABLED=true
COMPLIANCE_ARCHIVE_BUCKET=virelle-compliance-private
COMPLIANCE_RETENTION_DAYS=90
COMPLIANCE_ARCHIVE_SCAN_INTERVAL_MS=300000
COMPLIANCE_ARCHIVE_BATCH_SIZE=3
COMPLIANCE_ARCHIVE_MAX_BYTES=2147483648
COMPLIANCE_SIGNED_URL_SECONDS=300
# Keep false. Set true only when the shared bucket has an enforced policy that
# denies all public access to the compliance-archive/ prefix.
COMPLIANCE_ALLOW_SHARED_BUCKET=false

# ── Recorded Broadcast Bridge ─────────────────────────────────
# Bridge must record every session and return recordingUrl or outputUrl before
# Virelle starts transmission. The URL must remain downloadable after completion.
BROADCAST_BRIDGE_URL=https://broadcast-bridge.example.com/v1/sessions
BROADCAST_BRIDGE_TOKEN=replace-with-a-long-random-service-token
VIRELLE_BYOK_RENDER_WORKER=true

# ── Social Media Channels (optional) ─────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_CHANNEL_ID=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
META_ACCESS_TOKEN=
X_API_KEY=
X_API_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
LINKEDIN_ACCESS_TOKEN=
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

# ── Google Indexing (optional SEO) ────────────────────────────
GOOGLE_INDEXING_SA_KEY=
