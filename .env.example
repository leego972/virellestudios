# ============================================================
# VIRELLE STUDIOS — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# See DEPLOYMENT.md for setup instructions.
# ============================================================

# ── Core ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
PUBLIC_APP_URL=https://virelle.life

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/virelle

# ── Redis (rate limiting + job queues) ───────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# ── Stripe (payments + Adult Studio identity/card checks) ────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Subscription price IDs
STRIPE_INDIE_MONTHLY_PRICE_ID=price_...
STRIPE_INDIE_ANNUAL_PRICE_ID=price_...
STRIPE_CREATOR_MONTHLY_PRICE_ID=price_...
STRIPE_CREATOR_ANNUAL_PRICE_ID=price_...
STRIPE_STUDIO_MONTHLY_PRICE_ID=price_...
STRIPE_STUDIO_ANNUAL_PRICE_ID=price_...

# Credit top-up pack price IDs
STRIPE_TOPUP_10_PRICE_ID=price_...
STRIPE_TOPUP_30_PRICE_ID=price_...
STRIPE_TOPUP_100_PRICE_ID=price_...

# Stripe Connect
STRIPE_CONNECT_RETURN_URL=https://virelle.life/settings?tab=billing
STRIPE_CONNECT_REFRESH_URL=https://virelle.life/settings?tab=billing

# ── Adult Studio phone verification ──────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_VERIFY_SERVICE_SID=VA...

# ── AI Generation Providers ──────────────────────────────────
# Platform-level keys used as fallback for admin/testing.
# Users supply their own BYOK keys via Settings.
OPENAI_API_KEY=sk-...
RUNWAY_API_KEY=...
FAL_KEY=...
GOOGLE_API_KEY=...
HUGGING_FACE_API_KEY=...
GROQ_API_KEY=gsk_...

# ── Email ────────────────────────────────────────────────────
GMAIL_USER=studiosvirelle@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
EMAIL_FROM=Virelle Studios <studiosvirelle@gmail.com>

# ── Admin ────────────────────────────────────────────────────
ADMIN_EMAIL=your-admin-email@example.com

# ── App Storage (S3-compatible) ──────────────────────────────
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=virelle-uploads
AWS_S3_ENDPOINT=
AWS_S3_PUBLIC_URL=

# ── Private compliance archive ───────────────────────────────
# Use a private, encrypted bucket with no public-read policy.
COMPLIANCE_ARCHIVE_BUCKET=virelle-compliance-private
COMPLIANCE_RETENTION_DAYS=90
COMPLIANCE_ARCHIVE_ENABLED=true
COMPLIANCE_ARCHIVE_SCAN_INTERVAL_MS=300000
COMPLIANCE_ARCHIVE_BATCH_SIZE=3
COMPLIANCE_ARCHIVE_MAX_BYTES=2147483648
COMPLIANCE_SIGNED_URL_SECONDS=300

# ── Recorded broadcast bridge ────────────────────────────────
# Bridge v2 must record every session and call the verified completion endpoint.
BROADCAST_BRIDGE_URL=https://broadcast-bridge.example.com/sessions
BROADCAST_BRIDGE_TOKEN=replace-with-a-long-random-secret

# ── Social Media Channels (optional) ─────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_CHANNEL_ID=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
META_ACCESS_TOKEN=
X_API_KEY=
X_API_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
LINKEDIN_ACCESS_TOKEN=
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

# ── Google Indexing (optional SEO) ───────────────────────────
GOOGLE_INDEXING_SA_KEY=
