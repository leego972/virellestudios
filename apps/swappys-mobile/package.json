{
  "name": "swappys-mobile",
  "version": "1.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "doctor": "npx expo-doctor",
    "build:ios": "npx eas-cli build --platform ios --profile production --auto-submit",
    "build:android": "npx eas-cli build --platform android --profile production --auto-submit",
    "build:all": "npx eas-cli build --platform all --profile production --auto-submit --non-interactive",
    "submit:ios": "npx eas-cli submit --platform ios --profile production"
  },
  "dependencies": {
    "expo": "^52.0.0",
    "expo-constants": "~17.0.8",
    "expo-file-system": "~18.0.4",
    "expo-linking": "~7.0.5",
    "expo-media-library": "~17.0.6",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-webview": "13.12.5"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "~5.3.3"
  }
}
