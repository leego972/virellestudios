{
  "expo": {
    "name": "Swappys",
    "slug": "swappys",
    "scheme": "swappys",
    "version": "1.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Swappys needs photo library access to select transformation images.",
          "savePhotosPermission": "Swappys needs photo library access to save transformation previews.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.virelle.swappys",
      "buildNumber": "2",
      "infoPlist": {
        "NSCameraUsageDescription": "Swappys uses the camera only when you choose to capture a source face.",
        "NSPhotoLibraryUsageDescription": "Swappys lets you choose consented source and target images from your library.",
        "NSPhotoLibraryAddUsageDescription": "Swappys saves a transformation preview only when you tap Save.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "android": {
      "package": "com.virelle.swappys",
      "versionCode": 2,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ]
    },
    "extra": {
      "virelleBaseUrl": "https://virelle.life",
      "virelleUpgradeUrl": "https://virelle.life/register?source=swappys-mobile&campaign=result-upgrade&product=swappys&intent=creator-upgrade",
      "virelleLoginUrl": "https://virelle.life/login?source=swappys-mobile&campaign=result-signin",
      "eas": {
        "projectId": "14f30d0d-2798-463b-b7db-b8e237286313"
      }
    },
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#07070e"
    }
  }
}
