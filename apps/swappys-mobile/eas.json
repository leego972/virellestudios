{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "ios": {
        "credentialsSource": "remote"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "distribution": "store"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascApiKeyIssuerId": "d7c6c514-df7f-4adb-a4a0-b0553ea751a4",
        "ascApiKeyId": "2WG5YUFL55",
        "ascApiKeyPath": "$EXPO_APPLE_API_KEY_PATH",
        "appleTeamId": "5AUSX9646V",
        "ascAppId": "6787028397",
        "language": "en-US"
      },
      "android": {
        "serviceAccountKeyPath": "$GOOGLE_SERVICE_ACCOUNT_KEY",
        "track": "internal"
      }
    }
  }
}
