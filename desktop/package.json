{
  "name": "virelle-studios-desktop",
  "productName": "Virelle Studios",
  "version": "1.0.0",
  "description": "Virelle Studios desktop app — native window for the AI filmmaking platform.",
  "main": "main.js",
  "private": true,
  "author": {
    "name": "Virelle Studios",
    "email": "support@virelle.life"
  },
  "homepage": "https://www.virelle.life",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "dev": "VIRELLE_TARGET=https://www.virelle.life electron .",
    "dev:local": "VIRELLE_TARGET=http://localhost:3000 electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "life.virelle.studios.desktop",
    "productName": "Virelle Studios",
    "copyright": "Copyright © 2026 Virelle Studios",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "protocols": [
      {
        "name": "Virelle Deep Link",
        "schemes": ["virelle"]
      }
    ],
    "mac": {
      "category": "public.app-category.video",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "build/icon.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Virelle Studios"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "icon": "build/icon.png",
      "category": "AudioVideo",
      "synopsis": "AI filmmaking platform"
    },
    "publish": null
  }
}
